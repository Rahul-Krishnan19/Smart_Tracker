# Application
APP_NAME=ExpenseTracker
DEBUG=False
SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_URL=../data/database/expense_tracker.db

# Encryption
ENCRYPTION_KEY_PATH=../data/credentials/master.key

# Gmail OAuth (Set up after creating Google Cloud project)
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/gmail/callback

# Security
ALLOWED_ORIGINS=http://localhost:3000
SESSION_EXPIRE_HOURS=24
JWT_EXPIRE_MINUTES=30

# Email Cleanup
EMAIL_RETENTION_DAYS=30
