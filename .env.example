# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://expense:your_db_password@db:5432/expense_tracker
DB_PASSWORD=your_db_password

# SQLite (local dev only — leave DATABASE_URL unset and it defaults to SQLite)
# DATABASE_URL=sqlite:///./data/database/expense_tracker.db

# ─── Security ─────────────────────────────────────────────────────────────────
# Random 32+ char string for JWT signing
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# Fernet key for encrypting Gmail OAuth tokens
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set to true to require Google Authenticator on login
ENABLE_TOTP=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com

# ─── Gmail OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/gmail/callback
